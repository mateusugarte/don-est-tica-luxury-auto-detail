{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/_shell.html" },
    { "source": "/((?!assets/|.*\\..*).*)", "destination": "/_shell.html" }
  ]
}
